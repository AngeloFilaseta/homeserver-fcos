# Formato: <server:/export> <mountpoint> <type> <options> <dump> <pass>
# Nota: x-systemd.automount crea automount automatico on-demand.

192.168.1.198:/volume1/media /mnt/nas/media nfs defaults,_netdev,nofail,noatime,x-systemd.automount,x-systemd.idle-timeout=10min,timeo=14,retrans=3 0 0
192.168.1.198:/volume1/smarthome /mnt/nas/smarthome nfs defaults,_netdev,nofail,noatime,x-systemd.automount,x-systemd.idle-timeout=10min,timeo=14,retrans=3 0 0
